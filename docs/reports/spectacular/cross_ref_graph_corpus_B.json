    {
      "id": "fallacy_1",
      "label": "fallacy_1",
      "type": "fallacy",
      "metadata": {
        "data": {
          "type": "Appel à la pitié",
          "justification": "Utilise la souffrance et les sacrifices du peuple pour légitimer les annexions et disqualifier les critiques, substituant l'émotion à un argument factuel.",
          "target_argument_id": "arg_1"
        }
      }
    },
    {
      "id": "fallacy_2",
      "label": "fallacy_2",
      "type": "fallacy",
      "metadata": {
        "data": {
          "type": "Faux dilemme",
          "justification": "Présente seulement deux solutions opposées (importer ou expansion territoriale) comme si aucune autre option économique ou diplomatique n'existait, éliminant des alternatives raisonnables.",
          "target_argument_id": "arg_4"
        }
      }
    },
    {
      "id": "fallacy_3",
      "label": "fallacy_3",
      "type": "fallacy",
      "metadata": {
        "data": {
          "type": "Généralisation abusive / stéréotype",
          "justification": "Attribue des caractéristiques malveillantes et uniformes à l'ensemble d'un groupe (les Juifs), sans preuve suffisante, en les présentant comme une conspiration mondiale.",
          "target_argument_id": "arg_5"
        }
      }
    },
    {
      "id": "fallacy_4",
      "label": "fallacy_4",
      "type": "fallacy",
      "metadata": {
        "data": {
          "type": "Appel à la peur (argumentum ad metum)",
          "justification": "Emploie la peur d'une menace existentielle (surpopulation, annihilation, Bolshevization, guerre mondiale orchestrée par les Juifs) pour justifier des politiques extrêmes.",
          "target_argument_id": "arg_4"
        }
      }
    },
    {
      "id": "fallacy_5",
      "label": "fallacy_5",
      "type": "fallacy",
      "metadata": {
        "data": {
          "type": "Poisoning the well (Empoisonnement du puits)",
          "justification": "Délégitime a priori les critiques en les traitant d’« indignes » et de pessimistes, neutralisant ainsi leurs objections sans les examiner.",
          "target_argument_id": "arg_1"
        }
      }
    },
    {
      "id": "fallacy_6",
      "label": "fallacy_6",
      "type": "fallacy",
      "metadata": {
        "data": {
          "type": "Victim blaming (Culpabilisation de la victime)",
          "justification": "Présente les Tchécoslovaques et leur gouvernement comme responsables des actions allemandes en affirmant que leurs « provocations » rendaient l’intervention nécessaire, inversant la responsabilité.",
          "target_argument_id": "arg_2"
        }
      }
    },
    {
      "id": "fallacy_7",
      "label": "fallacy_7",
      "type": "fallacy",
      "metadata": {
        "data": {
          "type": "Appel à la pitié",
          "justification": "Le texte présente la souffrance et les sacrifices du peuple allemand comme preuve morale suffisante pour légitimer les annexions; substitution de l'émotion à une justification normative.",
          "target_argument_id": "arg_1"
        }
      }
    },
    {
